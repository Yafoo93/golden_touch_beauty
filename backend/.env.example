DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_LOG_LEVEL=INFO

POSTGRES_DB=golden_touch_beauty
POSTGRES_USER=golden_touch
POSTGRES_PASSWORD=golden_touch_local
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

FRONTEND_URL=http://localhost:3000
DEFAULT_FROM_EMAIL=Golden Touch Beauty Centre <noreply@goldentouch.local>

# Local tests use SQLite by default. CI overrides this with PostgreSQL.
TEST_DATABASE_ENGINE=sqlite
